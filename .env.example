# ============================================================
# LDC Shop 环境配置文件 / Environment Configuration
# 复制此文件为 .env 并修改配置 / Copy to .env and modify
# ============================================================

# ---- 应用端口 / App Port ----
# 映射到宿主机的端口 / Port mapped to host
APP_PORT=3000

# ---- MySQL 配置 / MySQL Config ----
# standalone: 自动创建 MySQL 容器, 无需修改 HOST
# external:   需要配置指向已有的 MySQL 地址
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_EXTERNAL_PORT=3306
MYSQL_DATABASE=ldc_shop
MYSQL_USERNAME=root
MYSQL_ROOT_PASSWORD=ldc_shop_2024
MYSQL_PASSWORD=ldc_shop_2024

# ---- Redis 配置 / Redis Config ----
# standalone: 自动创建 Redis 容器, 无需修改 HOST
# external:   需要配置指向已有的 Redis 地址
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_EXTERNAL_PORT=6379
REDIS_PASSWORD=ldc_shop_redis_2024
REDIS_DATABASE=0

# ---- Sa-Token 配置 / Sa-Token Config ----
# JWT 密钥, 请务必修改! / JWT secret, MUST change in production!
SA_TOKEN_JWT_SECRET=please-change-this-secret-in-production-abc123xyz

# ---- LINUX DO OAuth 配置 / OAuth Config ----
LDC_OAUTH_CLIENT_ID=
LDC_OAUTH_CLIENT_SECRET=
LDC_OAUTH_REDIRECT_URI=https://example.com/auth/callback
LDC_OAUTH_AUTHORIZE_URL=https://connect.linux.do/oauth2/authorize
LDC_OAUTH_TOKEN_URL=https://connect.linux.do/oauth2/token
LDC_OAUTH_USER_INFO_URL=https://connect.linux.do/api/user

# ---- LDC Credit 支付配置 / Payment Config ----
LDC_PAYMENT_CLIENT_ID=
LDC_PAYMENT_CLIENT_SECRET=
LDC_PAYMENT_PUBLIC_KEY=
LDC_PAYMENT_GATEWAY_URL=https://credit.linux.do/epay
# 支付异步通知地址(需公网可访问) / Payment notify URL (must be publicly accessible)
LDC_PAYMENT_NOTIFY_URL=https://example.com/api/order/notify
# 支付完成后跳转地址 / Payment return URL
LDC_PAYMENT_RETURN_URL=https://example.com/order/result

# ---- CORS 跨域配置 / CORS Config ----
# 允许的前端域名(逗号分隔) / Allowed frontend origins (comma separated)
CORS_ALLOWED_ORIGINS=https://example.com

# ---- 管理员配置 / Admin Config ----
# 首次登录自动设为管理员的用户名(逗号分隔) / Auto-admin usernames (comma separated)
LDC_ADMIN_USERNAMES=admin,root

# ---- 订单配置 / Order Config ----
# 未支付订单自动关闭超时(分钟) / Auto-close timeout for unpaid orders (minutes)
ORDER_AUTO_CLOSE_MINUTES=30

# ---- JVM 参数 / JVM Options ----
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC
