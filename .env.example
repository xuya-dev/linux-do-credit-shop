# ============================================================
# LDC Shop 环境配置文件 / Environment Configuration
# 复制此文件为 .env 并修改配置 / Copy to .env and modify
# ============================================================

# ---- Spring Profile ----
# dev=开发模式, prod=生产模式 / dev=development, prod=production
SPRING_PROFILES_ACTIVE=prod

# ---- 应用端口 / App Port ----
# 映射到宿主机的端口 / Port mapped to host
APP_PORT=3000

# ---- MySQL 配置 / MySQL Config ----
# standalone: 自动创建 MySQL 容器, 无需修改 HOST
# external:   需要配置指向已有的 MySQL 地址
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_EXTERNAL_PORT=3306
MYSQL_DATABASE=ldc_shop
MYSQL_USERNAME=root
MYSQL_ROOT_PASSWORD=please-change-this-mysql-password
MYSQL_PASSWORD=please-change-this-mysql-password

# ---- Redis 配置 / Redis Config ----
# standalone: 自动创建 Redis 容器, 无需修改 HOST
# external:   需要配置指向已有的 Redis 地址
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_EXTERNAL_PORT=6379
REDIS_PASSWORD=please-change-this-redis-password
REDIS_DATABASE=0

# ---- Sa-Token 配置 / Sa-Token Config ----
# JWT 密钥, 请务必修改为随机字符串! / JWT secret, MUST change to a random string!
SA_TOKEN_JWT_SECRET=please-change-this-to-a-random-secret

# ---- LINUX DO OAuth 配置（登录前必须可用）/ OAuth Config (required before login) ----
LDC_OAUTH_CLIENT_ID=
LDC_OAUTH_CLIENT_SECRET=
LDC_OAUTH_REDIRECT_URI=https://example.com/auth/callback
LDC_OAUTH_AUTHORIZE_URL=https://connect.linux.do/oauth2/authorize
LDC_OAUTH_TOKEN_URL=https://connect.linux.do/oauth2/token
LDC_OAUTH_USER_INFO_URL=https://connect.linux.do/api/user

# ---- 管理员配置（登录时判断角色）/ Admin Config (used during login) ----
# 首次登录自动设为管理员的用户名(逗号分隔) / Auto-admin usernames (comma separated)
LDC_ADMIN_USERNAMES=admin,root

# ---- 卡密加密密钥 / Card Encryption Secret ----
# 用于 AES-256-GCM 加密卡密内容, 请务必修改! / For AES-256-GCM card encryption, MUST change!
# 至少 32 个字符 / At least 32 characters
CARD_ENCRYPT_SECRET=please-change-this-encryption-secret-key

# ---- CORS 跨域配置 / CORS Config ----
# 允许的前端域名(逗号分隔) / Allowed frontend origins (comma separated)
CORS_ALLOWED_ORIGINS=https://example.com

# ---- 订单配置 / Order Config ----
# 未支付订单自动关闭超时(分钟) / Auto-close timeout for unpaid orders (minutes)
ORDER_AUTO_CLOSE_MINUTES=30

# ---- JVM 参数 / JVM Options ----
# JDK 21 推荐使用 ZGC 配合虚拟线程 / JDK 21 recommends ZGC with virtual threads
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseZGC
