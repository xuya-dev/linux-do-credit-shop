# ---- IDE ----
.vscode/
*.swp
*.swo
*~

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Docker / Env ----
.env

# ---- Logs ----
logs/
*.log

# ---- Temp ----
*.tmp
*.temp
.cache/
